{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "nexuxtendev",
    "compatibility_date": "2026-05-04",
    "main": ".open-next/worker.js",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "services": [
        {
            "binding": "WORKER_SELF_REFERENCE",
            "service": "nexuxtendev"
        }
    ]
}